{
  "rewrites": [
    {
      "source": "/shop/:username",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": "(?i)(twitterbot|facebookexternalhit|whatsapp|pinterest|linkedinbot|discordbot)"
        }
      ],
      "destination": "/api/shop/:username"
    }
  ]
}
