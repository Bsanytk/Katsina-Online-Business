rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------
    // Users
    // --------------------------
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      // Create/update own profile but cannot set role from client
      allow create, update: if request.auth != null && request.auth.uid == uid
        && !(request.resource.data.keys().hasAny(['role']) && (resource.data.role != request.resource.data.role));

      allow delete: if false;
    }

    // --------------------------
    // Products
    // --------------------------
    match /products/{productId} {
      // Public read for marketplace browsing
      allow read: if true;

      // Only authenticated users may create a product and ownerUid must match
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.keys().hasAll(['title', 'price', 'ownerUid']);

      // Only product owner or admin may update/delete
      allow update, delete: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // --------------------------
    // Reviews
    // --------------------------
    match /reviews/{reviewId} {
      // Allow anyone to read reviews
      allow read: if true;

      // Only authenticated buyer can create review and buyerId must be auth.uid
      allow create: if request.auth != null
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.keys().hasAll(['productId','sellerId','buyerId','rating','text']);

      // Only the author can update or delete their review
      allow update, delete: if request.auth != null && resource.data.buyerId == request.auth.uid;
    }

    // --------------------------
    // Orders (simplified 'requests')
    // --------------------------
    match /orders/{orderId} {
      // Only participants (buyer or seller) can read
      allow read: if request.auth != null && (
        resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid
      );

      // Buyer can create a request (buyerId must match)
      allow create: if request.auth != null && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.keys().hasAll(['buyerId','sellerId','productId']);

      // Only seller (resource.sellerId) or admin may update status fields
      allow update: if request.auth != null && (
        resource.data.sellerId == request.auth.uid
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );

      // Only admin may delete
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --------------------------
    // Conversations & Messages
    // --------------------------
    match /conversations/{conversationId} {
      // Only participants can read/get conversation
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;

      // To create a conversation, the request must include participants array and auth uid must be one of them
      allow create: if request.auth != null
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.keys().hasAll(['participants','productId']);

      // prevent client from changing participants array after creation
      allow update: if request.auth != null && request.auth.uid in resource.data.participants
        && !(request.resource.data.keys().hasAny(['participants']) && request.resource.data.participants != resource.data.participants);

      // Messages subcollection
      match /messages/{messageId} {
        // Only participants can read messages
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;

        // Only authenticated sender may create message and senderId must match auth uid
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          && request.resource.data.keys().hasAll(['conversationId','senderId','text','createdAt']);

        // Allow sender to update their own message (e.g., edit) within limits
        allow update: if request.auth != null && resource.data.senderId == request.auth.uid;

        // No client deletes of messages
        allow delete: if false;
      }
    }

    // --------------------------
    // Default deny
    // --------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
